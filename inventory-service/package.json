{
  "name": "@helpme/inventory-service",
  "version": "1.0.0",
  "description": "Inventory Service — gerenciamento de inventário do Help-Me",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "test": "vitest run --config vitest.config.ts",
    "test:unit": "vitest --clearCache && vitest run",
    "test:watch": "vitest --config vitest.config.ts",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:carga": "k6 run __tests__/performance/load.k6.js",
    "migrate": "dotenv -e .env -- prisma migrate dev",
    "generate": "dotenv -e .env -- prisma generate",
    "migrate:reset": "dotenv -e .env -- prisma migrate reset --force",
    "studio": "dotenv -e .env -- prisma studio",
    "seed": "tsx --env-file=.env prisma/seed.ts",
    "migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "7.6.0",
    "axios": "^1.14.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "minio": "^8.0.7",
    "ms": "^2.1.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "7.6.0",
    "qs": "^6.15.0",
    "redis": "^5.11.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/pg": "8.20.0",
    "@types/qs": "^6.15.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "dotenv": "^17.4.0",
    "dotenv-cli": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.1"
}
