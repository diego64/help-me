# ======================================
# ELASTICSEARCH
# ======================================
ELASTICSEARCH_PORT=9200

# ======================================
# KIBANA
# ======================================
KIBANA_PORT=5601
# Deve ter exatamente 32+ caracteres
KIBANA_ENCRYPTION_KEY=auth-service-elk-key-32-chars-ok

# ======================================
# FILEBEAT
# ======================================
# Diretório onde o auth-service grava os logs (deve coincidir com LOG_FILE no .env)
# Exemplo: se LOG_FILE=./logs/auth-service.log → LOG_FILE_DIR=../logs (relativo ao elk/)
LOG_FILE_DIR=../logs

# ======================================
# APLICAÇÃO (para label no Filebeat)
# ======================================
NODE_ENV=development
