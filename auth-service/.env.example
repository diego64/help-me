# ─────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
# Caminho do arquivo de log para ingestão pelo Filebeat (ELK)
# Deixe vazio para logar apenas no stdout
LOG_FILE=./logs/auth-service.log

# ─────────────────────────────────────────────
# DATABASE (PostgreSQL dedicado do auth-service)
# ─────────────────────────────────────────────
DB_USER=auth_user
DB_PASSWORD=auth_pass
DB_NAME=auth-database
DB_HOST=localhost
DB_PORT=5433
DB_MAX_CONNECTIONS=50
DB_SHARED_BUFFERS=128MB
DB_EFFECTIVE_CACHE_SIZE=512MB
POSTGRESQL_WORK_MEM=8MB

DATABASE_URL=postgresql://auth_user:auth_pass@localhost:5433/auth-database?connection_limit=10&pool_timeout=60&connect_timeout=30&statement_timeout=60000

# ─────────────────────────────────────────────
# REDIS (instância dedicada do auth-service)
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_SECRET=troque-por-um-secret-forte-em-producao
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=troque-por-um-refresh-secret-diferente
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# KAFKA
# ─────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=auth-service
KAFKA_GROUP_ID=auth-service-group

# ─────────────────────────────────────────────
# BCRYPT
# ─────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

