# ─────────────────────────────────────────────
# AUTH SERVICE — AMBIENTE DE TESTE E2E
# Nunca usar esses valores em produção
# ─────────────────────────────────────────────
NODE_ENV=test
PORT=0

# ─────────────────────────────────────────────
# DATABASE (PostgreSQL dedicado para testes E2E)
# Suba com: docker compose up auth-postgres-test -d
# ─────────────────────────────────────────────
DB_USER=administrator
DB_PASSWORD=1qaz2wsx3edc
DB_NAME=auth-test
DB_HOST=localhost
DB_PORT=5490
DB_MAX_CONNECTIONS=10

DATABASE_URL=postgresql://administrator:1qaz2wsx3edc@localhost:5490/auth-test?connection_limit=5&pool_timeout=30&connect_timeout=15

# ─────────────────────────────────────────────
# REDIS (instância dedicada para testes E2E)
# Suba com: docker compose up auth-redis-test -d
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6392
REDIS_PASSWORD=1qaz2wsx3edc

# ─────────────────────────────────────────────
# JWT (secrets exclusivos para testes — nunca usar em produção)
# ─────────────────────────────────────────────
JWT_SECRET=HelpMeApp2024JwtTokenTestSecretABCDEFGhij
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=HelpMeApp2024RefreshTokenSecretXYZpqrstuvwx
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# KAFKA (producer não se conecta em testes — circuit breaker descarta eventos)
# ─────────────────────────────────────────────
KAFKA_BROKERS=localhost:29092
KAFKA_CLIENT_ID=auth-service-test
KAFKA_GROUP_ID=auth-service-test-group
