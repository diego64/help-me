generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum Regra {
  ADMIN
  TECNICO
  USUARIO
}

enum ChamadoStatus {
  ABERTO
  EM_ATENDIMENTO
  ENCERRADO
  CANCELADO
  REABERTO
}

enum PrioridadeChamado {
  P1
  P2
  P3
  P4
  P5
}

enum NivelTecnico {
  N1
  N2
  N3
}

enum Setor {
  ADMINISTRACAO
  ALMOXARIFADO
  CALL_CENTER
  COMERCIAL
  DEPARTAMENTO_PESSOAL
  FINANCEIRO
  JURIDICO
  LOGISTICA
  MARKETING
  QUALIDADE
  RECURSOS_HUMANOS
  TECNOLOGIA_INFORMACAO
}

// ==================== MODELS ====================

model Usuario {
  id                     String        @id @default(cuid())
  nome                   String        @db.VarChar(100)
  sobrenome              String        @db.VarChar(100)
  email                  String        @unique @db.VarChar(255)
  password               String        @db.VarChar(512)
  regra                  Regra
  nivel                  NivelTecnico? @default(N1)
  setor                  Setor?
  telefone               String?
  ramal                  String?
  avatarUrl              String?

  geradoEm               DateTime    @default(now()) @map("gerado_em") @db.Timestamptz(3)
  atualizadoEm           DateTime    @updatedAt @map("atualizado_em") @db.Timestamptz(3)
  deletadoEm             DateTime?   @map("deletado_em") @db.Timestamptz(3)
  ativo                  Boolean     @default(true)
  refreshToken           String?

  chamadoOS              Chamado[]   @relation("UsuarioChamado")
  tecnicoChamados        Chamado[]   @relation("TecnicoResponsavel")
  tecnicoDisponibilidade Expediente[]

  // Sistema de Transferência
  transferenciasRealizadas TransferenciaChamado[] @relation("TransferenciasRealizadas")
  transferenciasRecebidas  TransferenciaChamado[] @relation("TransferenciasPara")
  transferenciasEnviadas   TransferenciaChamado[] @relation("TransferenciasDe")

  // Sistema de Priorização
  alteracoesPrioridade     Chamado[]              @relation("AlteracoesPrioridade")

  // Sistema de Comentários
  comentarios              ComentarioChamado[]

  // Sistema de Anexos
  anexos                   AnexoChamado[]

  // ==================== INDEX ====================

  @@index([email])
  @@index([regra])
  @@index([nivel])
  @@index([ativo])
  @@index([setor])
  @@index([deletadoEm])
  @@index([regra, nivel])
  @@map("usuarios")
}

model Expediente {
  id           String   @id @default(cuid())
  usuario      Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId    String
  entrada      DateTime @db.Timestamptz(3)
  saida        DateTime @db.Timestamptz(3)

  geradoEm     DateTime  @default(now()) @map("gerado_em") @db.Timestamptz(3)
  atualizadoEm DateTime  @updatedAt @map("atualizado_em") @db.Timestamptz(3)
  deletadoEm   DateTime? @map("deletado_em") @db.Timestamptz(3)
  ativo        Boolean   @default(true)

  @@index([usuarioId])
  @@map("expedientes")
}

model Servico {
  id           String   @id @default(cuid())
  nome         String   @unique
  descricao    String?

  geradoEm     DateTime  @default(now()) @map("gerado_em") @db.Timestamptz(3)
  atualizadoEm DateTime  @updatedAt @map("atualizado_em") @db.Timestamptz(3)
  deletadoEm   DateTime? @map("deletado_em") @db.Timestamptz(3)
  ativo        Boolean   @default(true)

  chamados     OrdemDeServico[]

  @@index([nome])
  @@index([ativo])
  @@index([deletadoEm])
  @@map("servicos")
}

model Chamado {
  id                    String            @id @default(cuid())
  OS                    String            @unique @db.VarChar(50)
  descricao             String            @db.Text
  status                ChamadoStatus     @default(ABERTO)
  descricaoEncerramento String?           @map("descricao_encerramento") @db.Text

  geradoEm     DateTime  @default(now()) @map("gerado_em") @db.Timestamptz(3)
  atualizadoEm DateTime  @updatedAt @map("atualizado_em") @db.Timestamptz(3)
  encerradoEm  DateTime? @map("encerrado_em") @db.Timestamptz(3)
  deletadoEm   DateTime? @map("deletado_em") @db.Timestamptz(3)

  usuario      Usuario  @relation("UsuarioChamado", fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId    String   @map("usuario_id")

  tecnico      Usuario? @relation("TecnicoResponsavel", fields: [tecnicoId], references: [id], onDelete: SetNull)
  tecnicoId    String?  @map("tecnico_id")

  servicos     OrdemDeServico[]

  prioridade            PrioridadeChamado @default(P4)
  prioridadeAlterada    DateTime?         @map("prioridade_alterada") @db.Timestamptz(3)
  prioridadeAlteradaPor String?           @map("prioridade_alterada_por")

  alteradorPrioridade   Usuario?          @relation("AlteracoesPrioridade", fields: [prioridadeAlteradaPor], references: [id], onDelete: SetNull)

  transferencias        TransferenciaChamado[]
  comentarios           ComentarioChamado[]
  anexos                AnexoChamado[]

  // ==================== INDEX ====================

  @@index([usuarioId])
  @@index([tecnicoId])
  @@index([status])
  @@index([geradoEm])
  @@index([OS])
  @@index([deletadoEm])
  @@index([status, geradoEm])
  @@index([tecnicoId, status])
  @@index([usuarioId, status])
  @@index([prioridade])
  @@index([prioridade, status])
  @@index([status, prioridade, geradoEm])
  @@index([prioridadeAlteradaPor])
  @@map("chamados")
}

model OrdemDeServico {
  id         String   @id @default(cuid())
  chamado    Chamado  @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  chamadoId  String   @map("chamado_id")

  servico    Servico  @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  servicoId  String   @map("servico_id")

  geradoEm     DateTime  @default(now()) @map("gerado_em") @db.Timestamptz(3)
  atualizadoEm DateTime  @updatedAt @map("atualizado_em") @db.Timestamptz(3)
  deletadoEm   DateTime? @map("deletado_em") @db.Timestamptz(3)

  @@unique([chamadoId, servicoId], name: "unique_chamado_servico")
  @@index([chamadoId])
  @@index([servicoId])
  @@index([deletadoEm])
  @@map("ordens_de_servico")
}

model TransferenciaChamado {
  id                String   @id @default(cuid())
  chamadoId         String   @map("chamado_id")
  tecnicoAnteriorId String?  @map("tecnico_anterior_id")
  tecnicoNovoId     String   @map("tecnico_novo_id")
  motivo            String   @db.Text
  transferidoPor    String   @map("transferido_por")
  transferidoEm     DateTime @default(now()) @map("transferido_em") @db.Timestamptz(3)

  chamado           Chamado  @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  tecnicoAnterior   Usuario? @relation("TransferenciasDe", fields: [tecnicoAnteriorId], references: [id], onDelete: SetNull)
  tecnicoNovo       Usuario  @relation("TransferenciasPara", fields: [tecnicoNovoId], references: [id], onDelete: Cascade)
  transferidor      Usuario  @relation("TransferenciasRealizadas", fields: [transferidoPor], references: [id], onDelete: Cascade)

  @@index([chamadoId])
  @@index([tecnicoAnteriorId])
  @@index([tecnicoNovoId])
  @@index([transferidoPor])
  @@index([transferidoEm])
  @@map("transferencias_chamado")
}

model ComentarioChamado {
  id                  String    @id @default(cuid())
  chamadoId           String    @map("chamado_id")
  autorId             String    @map("autor_id")
  comentario          String    @db.Text
  visibilidadeInterna Boolean   @default(false) @map("visibilidade_interna")

  criadoEm            DateTime  @default(now()) @map("criado_em") @db.Timestamptz(3)
  atualizadoEm        DateTime  @updatedAt @map("atualizado_em") @db.Timestamptz(3)
  deletadoEm          DateTime? @map("deletado_em") @db.Timestamptz(3)

  chamado             Chamado  @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  autor               Usuario  @relation(fields: [autorId], references: [id], onDelete: Cascade)

  @@index([chamadoId])
  @@index([autorId])
  @@index([criadoEm])
  @@index([deletadoEm])
  @@index([chamadoId, deletadoEm])
  @@index([visibilidadeInterna])
  @@map("comentarios_chamado")
}

model AnexoChamado {
  id           String    @id @default(cuid())
  chamadoId    String    @map("chamado_id")
  autorId      String    @map("autor_id")
  nomeArquivo  String    @map("nome_arquivo") @db.VarChar(255)
  nomeOriginal String    @map("nome_original") @db.VarChar(255)
  mimetype     String    @db.VarChar(100)
  tamanho      Int
  bucketMinio  String    @map("bucket_minio") @db.VarChar(100)
  objetoMinio  String    @map("objeto_minio") @db.VarChar(255)

  criadoEm     DateTime  @default(now()) @map("criado_em") @db.Timestamptz(3)
  deletadoEm   DateTime? @map("deletado_em") @db.Timestamptz(3)

  chamado      Chamado  @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  autor        Usuario  @relation(fields: [autorId], references: [id], onDelete: Cascade)

  @@index([chamadoId])
  @@index([autorId])
  @@index([criadoEm])
  @@index([deletadoEm])
  @@index([chamadoId, deletadoEm])
  @@map("anexos_chamado")
}