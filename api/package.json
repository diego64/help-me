{
  "name": "help-me-api",
  "version": "1.1.1",
  "description": "API para help desk",
  "main": "index.js",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "Diego Ferreira L.G.Oliveira",
  "repository": {
    "type": "git",
    "url": "https://github.com/diego64/help-me.git"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsup",
    "start": "node --env-file=.env dist/server.js",
    "generate": "dotenv -e .env -- prisma generate",
    "migrate": "dotenv -e .env -- prisma migrate dev",
    "migrate:reset": "dotenv -e .env -- prisma migrate reset --force",
    "studio": "dotenv -e .env -- prisma studio",
    "seed": "tsx --env-file=.env prisma/seed.ts",
    "seed-medium": "tsx --env-file=.env prisma/seed-medium.ts",
    "seed-big": "tsx --env-file=.env prisma/seed-big.ts",
    "seed-big-ci": "tsx --env-file=.env.test prisma/seed-big.ts",
    "prisma:reset": "dotenv -e .env -- prisma migrate reset --force",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "dotenv -e .env.test -- vitest run --config vitest.config.e2e.ts",
    "test:e2e:watch": "dotenv -e .env.test -- vitest --config vitest.config.e2e.ts",
    "test:e2e:ui": "dotenv -e .env.test -- vitest --ui --config vitest.config.e2e.ts",
    "test:e2e:coverage": "dotenv -e .env.test -- vitest run --coverage --config vitest.config.e2e.ts",
    "test:all": "pnpm run test:unit && sleep 3 && pnpm run test:e2e",
    "test:teardown": "docker compose -f docker-compose.yaml stop postgresql_helpme_teste mongodb_helpme_teste",
    "extracao-de-rotas": "node --env-file=.env scripts/extracao-de-rotas.cjs",
    "test:carga": "DISABLE_RATE_LIMIT=true pnpm run extracao-de-rotas && k6 run src/__tests__/performance/carga/carga.js",
    "test:soak": "pnpm run extracao-de-rotas && k6 run src/__tests__/performance/soak/soak.js",
    "test:spike": "pnpm run extracao-de-rotas && k6 run src/__tests__/performance/spike/spike.js",
    "test:stress": "pnpm run extracao-de-rotas && k6 run src/__tests__/performance/stress/stress.js"
  },
  "keywords": [],
  "packageManager": "pnpm@10.28.1",
  "dependencies": {
    "@influxdata/influxdb-client": "^1.35.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "7.3.0",
    "compression": "^1.8.1",
    "connect-redis": "^9.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "handlebars": "^4.7.8",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "mongodb": "^7.1.0",
    "mongoose": "^9.2.1",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.13",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "qs": "^6.15.0",
    "redis": "^5.11.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.0",
    "@types/nodemailer": "^7.0.10",
    "@types/pg": "^8.16.0",
    "@types/qs": "^6.14.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "4.0.18",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "7.3.0",
    "supertest": "^7.2.2",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "jws": ">=3.2.3",
      "glob": ">=11.1.0",
      "cross-spawn": ">=7.0.5",
      "brace-expansion": ">=2.0.2",
      "mem@<4.0.0": ">=4.0.0",
      "d3-color@<3.1.0": ">=3.1.0",
      "yargs-parser@>=6.0.0 <13.1.2": ">=13.1.2",
      "got@<11.8.5": ">=11.8.5",
      "tough-cookie@<4.1.3": ">=4.1.3",
      "tmp@<=0.2.3": ">=0.2.4",
      "form-data@<2.5.4": ">=2.5.4"
    },
    "ignoredBuiltDependencies": [
      "esbuild"
    ]
  }
}
