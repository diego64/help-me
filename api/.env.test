# ==================== AMBIENTE DE TESTE ====================
NODE_ENV=test

# ==================== BANCO DE DADOS (TESTE) ====================
DB_USER=teste
DB_PASSWORD=senha_teste
DB_NAME=helpme_database_teste
DB_HOST=localhost
DB_PORT=5433
DB_MAX_CONNECTIONS=50
DB_SHARED_BUFFERS=128MB
DB_EFFECTIVE_CACHE_SIZE=512MB
