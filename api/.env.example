# ==================== BANCO DE DADOS (PRINCIPAL) ====================
DB_USER=seu_usuario
DB_PASSWORD=sua_senha_segura
DB_NAME=nome_do_banco
DB_HOST=postgresql_helpme
DB_PORT=5432
DB_MAX_CONNECTIONS=100
DB_SHARED_BUFFERS=256MB
DB_EFFECTIVE_CACHE_SIZE=1GB
POSTGRESQL_WORK_MEM=16MB
NODE_ENV=development

# URL de conexão
DATABASE_URL=postgresql://seu_usuario:sua_senha_segura@postgresql_helpme:5432/nome_do_banco?connection_limit=15&pool_timeout=120&connect_timeout=60&statement_timeout=120000

# ==================== BANCO DE DADOS (TESTE) ====================
DB_USER_TESTE=usuario_teste
DB_PASSWORD_TESTE=senha_teste
DB_NAME_TESTE=nome_do_banco_teste
DB_HOST_TESTE=postgresql_helpme_test
DB_PORT_TESTE=5433

# URL de conexão para ambiente de teste
DATABASE_URL_TESTE=postgresql://usuario_teste:senha_teste@postgresql_helpme_test:5433/nome_do_banco_teste?schema=public&connection_limit=5

# ==================== BANCO DE DADOS (HISTÓRICO DE CHAMADOS) ====================
MONGO_INITDB_ROOT_USERNAME=usuario_mongo
MONGO_INITDB_ROOT_PASSWORD=senha_mongo_segura
MONGO_INITDB_DATABASE=nome_banco_mongo
MONGO_HOST=mongodb_helpme
MONGO_PORT=27017

MONGO_INITDB_URI='mongodb://usuario_mongo:senha_mongo_segura@mongodb_helpme:27017/nome_banco_mongo?authSource=admin'

# ==================== BANCO DE DADOS (HISTÓRICO DE CHAMADOS) - AMBIENTE DE TESTE ====================
MONGO_INITDB_ROOT_USERNAME_TESTE=usuario_mongo_teste
MONGO_INITDB_ROOT_PASSWORD_TESTE=senha_mongo_teste
MONGO_INITDB_DATABASE_TESTE=nome_banco_mongo_teste
MONGO_HOST_TESTE=mongodb_helpme_test
MONGO_PORT_TESTE=27018

MONGO_INITDB_URI_TESTE='mongodb://usuario_mongo_teste:senha_mongo_teste@mongodb_helpme_test:27018/nome_banco_mongo_teste?authSource=admin'

# ==================== JWT ====================
JWT_SECRET=gere_um_secret_seguro_com_openssl_rand_base64_64
JWT_REFRESH_SECRET=gere_outro_secret_seguro_com_openssl_rand_base64_64
JWT_EXPIRATION=8h
JWT_REFRESH_EXPIRATION=7d

# ==================== ZOOKEEPER ====================
ZOOKEEPER_CLIENT_PORT=2181
ZOOKEEPER_TICK_TIME=2000
ZOOKEEPER_HOST=zookeeper_helpme
ZOOKEEPER_PORT=2181    

# ==================== KAFKA ====================
KAFKA_HOST=kafka_helpme
KAFKA_PORT=9092
KAFKA_BROKER_ID=1
KAFKA_ZOOKEEPER_CONNECT=zookeeper_helpme:2181
KAFKA_REPLICATION_FACTOR=1
KAFKA_AUTO_CREATE_TOPICS=true
KAFKA_MIN_ISR=1
KAFKA_LOG_RETENTION_HOURS=168
KAFKAJS_NO_PARTITIONER_WARNING=1
KAFKA_BROKER_URL=kafka_helpme:9092

# ==================== CONTROL CENTER ====================
CONTROL_CENTER_PORT=9021
CONTROL_CENTER_HOST=control_center_helpme
CONTROL_CENTER_BOOTSTRAP_SERVERS=kafka_helpme:9092
CONTROL_CENTER_ZOOKEEPER_CONNECT=zookeeper_helpme:2181
CONTROL_CENTER_REPLICATION_FACTOR=1

# ==================== REDIS ====================
REDIS_PASSWORD=
REDIS_HOST=redis_helpme
REDIS_PORT=6379
REDIS_MAX_MEMORY=512mb 
REDIS_MAXMEMORY_POLICY=allkeys-lru               

# ==================== INFLUX ====================
INFLUX_USERNAME=usuario_influx
INFLUX_PASSWORD=senha_influx_segura
INFLUX_ORG=sua_organizacao
INFLUX_BUCKET=nome_do_bucket
INFLUX_RETENTION=720h
INFLUX_ADMIN_TOKEN=gere_um_token_com_openssl_rand_hex_32
INFLUX_HOST=influxdb_helpme
INFLUX_PORT=8086
INFLUX_HTTP_LOG_ENABLED=true
INFLUX_URL=http://influxdb_helpme:8086

# ==================== LOKI ====================
LOKI_HOST=loki_helpme
LOKI_PORT=3100
LOKI_URL=http://loki_helpme:3100

# ==================== GRAFANA ====================
GRAFANA_USER=admin
GRAFANA_PASSWORD=senha_grafana_segura
GRAFANA_HOST=grafana_helpme
GRAFANA_PORT=3001
GRAFANA_METRICS_ENABLED=true

# ==================== PROMETHEUS ====================
PROMETHEUS_HOST=prometheus_helpme
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d
PROMETHEUS_URL=http://prometheus_helpme:9090

# ==================== NODE EXPORTER ====================
NODE_EXPORTER_HOST=node_exporter_helpme
NODE_EXPORTER_PORT=9100

# ==================== CADVISOR ====================
CADVISOR_HOST=cadvisor_helpme
CADVISOR_PORT=8080

# ==================== POSTGRES EXPORTER ====================
POSTGRES_EXPORTER_HOST=postgres_exporter_helpme
POSTGRES_EXPORTER_PORT=9187

# ==================== MONGODB EXPORTER ====================
MONGODB_EXPORTER_HOST=mongodb_exporter_helpme
MONGODB_EXPORTER_PORT=9216

# ==================== REDIS EXPORTER ====================
REDIS_EXPORTER_HOST=redis_exporter_helpme
REDIS_EXPORTER_PORT=9121

# ==================== KAFKA EXPORTER ====================
KAFKA_EXPORTER_HOST=kafka_exporter_helpme
KAFKA_EXPORTER_PORT=9308

# ==================== EMAIL SMTP ====================
SMTP_HOST=smtp.seuservidor.com
SMTP_PORT=587
SMTP_USER=seu_usuario_smtp
SMTP_PASS=sua_senha_smtp
SMTP_FROM=noreply@seudominio.com

# ==================== URL BASE ====================
API_BASE_URL=http://localhost:3333
API_HOST=0.0.0.0
API_PORT=3333

# ==================== DADOS PARA TESTE DE CARGA ====================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=SenhaAdmin123!
USER_EMAIL=usuario@example.com
USER_PASSWORD=SenhaUser123!
TECNICO_EMAIL=tecnico@example.com
TECNICO_PASSWORD=SenhaTecnico123!
SERVICO_NOME=Suporte Técnico
DEBUG_MODE=false
SKIP_CHAMADO_CREATION=false
MOCK_CHAMADO_ID=

# ==================== LOGGING ====================
LOG_LEVEL=info
LOG_DIR=./logs
LOG_FILE=app.log