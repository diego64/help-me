# ==================== BANCO DE DADOS (PRINCIPAL) ====================
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_HOST=localhost
DB_PORT=5432
DB_MAX_CONNECTIONS=100
DB_SHARED_BUFFERS=256MB
DB_EFFECTIVE_CACHE_SIZE=1GB
POSTGRESQL_WORK_MEM=16MB
NODE_ENV=development

# URL de conexão
DATABASE_URL=postgresql://user:password@localhost:5432/database?connection_limit=15&pool_timeout=120&connect_timeout=60&statement_timeout=120000

# ==================== BANCO DE DADOS (HISTÓRICO DE CHAMADOS) ====================
MONGO_INITDB_ROOT_USERNAME=mongo_user
MONGO_INITDB_ROOT_PASSWORD=mongo_password
MONGO_INITDB_DATABASE=mongo_database
MONGO_HOST=localhost
MONGO_PORT=27017

MONGO_INITDB_URI=mongodb://user:password@localhost:27017/database?authSource=admin

# ==================== STORAGE ====================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=minio_user
MINIO_ROOT_PASSWORD=minio_password
MINIO_USE_SSL=false
MINIO_BUCKET=files-bucket

# ==================== JWT ====================
JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret
JWT_EXPIRATION=8h
JWT_REFRESH_EXPIRATION=7d

# ==================== ZOOKEEPER ====================
ZOOKEEPER_CLIENT_PORT=2181
ZOOKEEPER_TICK_TIME=2000
ZOOKEEPER_HOST=localhost
ZOOKEEPER_PORT=2181

# ==================== KAFKA ====================
KAFKA_HOST=localhost
KAFKA_PORT=9093
KAFKA_BROKER_ID=1
KAFKA_ZOOKEEPER_CONNECT=localhost:2181
KAFKA_REPLICATION_FACTOR=1
KAFKA_AUTO_CREATE_TOPICS=true
KAFKA_MIN_ISR=1
KAFKA_LOG_RETENTION_HOURS=168
KAFKAJS_NO_PARTITIONER_WARNING=1
KAFKA_BROKER_URL=localhost:9093

# ==================== CONTROL CENTER ====================
CONTROL_CENTER_PORT=9021
CONTROL_CENTER_HOST=localhost
CONTROL_CENTER_BOOTSTRAP_SERVERS=localhost:9093
CONTROL_CENTER_ZOOKEEPER_CONNECT=localhost:2181
CONTROL_CENTER_REPLICATION_FACTOR=1

# ==================== REDIS ====================
REDIS_PASSWORD=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_MAX_MEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# ==================== INFLUX ====================
INFLUX_USERNAME=influx_user
INFLUX_PASSWORD=influx_password
INFLUX_ORG=org
INFLUX_BUCKET=bucket_name
INFLUX_RETENTION=720h
INFLUX_ADMIN_TOKEN=your_influx_token
INFLUX_HOST=localhost
INFLUX_PORT=8086
INFLUX_HTTP_LOG_ENABLED=true
INFLUX_URL=http://localhost:8086

# ==================== LOKI ====================
LOKI_HOST=localhost
LOKI_PORT=3100
LOKI_URL=http://localhost:3100

# ==================== GRAFANA ====================
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_HOST=localhost
GRAFANA_PORT=3001
GRAFANA_METRICS_ENABLED=true

# ==================== PROMETHEUS ====================
PROMETHEUS_HOST=localhost
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d
PROMETHEUS_URL=http://localhost:9090

# ==================== NODE EXPORTER ====================
NODE_EXPORTER_HOST=localhost
NODE_EXPORTER_PORT=9100

# ==================== CADVISOR ====================
CADVISOR_HOST=localhost
CADVISOR_PORT=8080

# ==================== POSTGRES EXPORTER ====================
POSTGRES_EXPORTER_HOST=localhost
POSTGRES_EXPORTER_PORT=9187

# ==================== MONGODB EXPORTER ====================
MONGODB_EXPORTER_HOST=localhost
MONGODB_EXPORTER_PORT=9216

# ==================== REDIS EXPORTER ====================
REDIS_EXPORTER_HOST=localhost
REDIS_EXPORTER_PORT=9121

# ==================== KAFKA EXPORTER ====================
KAFKA_EXPORTER_HOST=localhost
KAFKA_EXPORTER_PORT=9308

# ==================== EMAIL SMTP ====================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com

# ==================== URL BASE ====================
API_BASE_URL=http://localhost:3333
API_HOST=0.0.0.0
API_PORT=3333

# ==================== DADOS PARA TESTE DE CARGA ====================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me
USER_EMAIL=user@example.com
USER_PASSWORD=change_me
TECNICO_EMAIL=tecnico@example.com
TECNICO_PASSWORD=change_me
SERVICO_NOME="Nome do Serviço"
DEBUG_MODE=false
SKIP_CHAMADO_CREATION=false
MOCK_CHAMADO_ID=

# ==================== LOGGING ====================
LOG_LEVEL=info
LOG_DIR=./logs
LOG_FILE=app.log

# ==================== AMBIENTE DE TESTES ====================

# Banco de dados
DB_USER_TESTE=test_user
DB_PASSWORD_TESTE=test_password
DB_NAME_TESTE=test_database
DB_HOST_TESTE=localhost
DB_PORT_TESTE=5435

DATABASE_URL_TESTE=postgresql://user:password@localhost:5435/test_database

# Mongo
MONGO_INITDB_ROOT_USERNAME_TESTE=test_user
MONGO_INITDB_ROOT_PASSWORD_TESTE=test_password
MONGO_INITDB_DATABASE_TESTE=test_database
MONGO_HOST_TESTE=localhost
MONGO_PORT_TESTE=27018

MONGO_INITDB_URI_TESTE=mongodb://user:password@localhost:27018/test_database?authSource=admin

# Storage
MINIO_PORT_TESTE=9002
MINIO_CONSOLE_PORT_TESTE=9003
MINIO_ROOT_USER_TESTE=minio_user
MINIO_ROOT_PASSWORD_TESTE=minio_password
MINIO_BUCKET_TESTE=test-bucket

# JWT
JWT_SECRET_TESTE=test_secret
JWT_REFRESH_SECRET_TESTE=test_refresh_secret
JWT_EXPIRATION_TESTE=8h
JWT_REFRESH_EXPIRATION_TESTE=7d

# Redis
REDIS_HOST_TESTE=localhost
REDIS_PORT_TESTE=6380

# Kafka
KAFKA_HOST_TESTE=localhost
KAFKA_PORT_TESTE=9095
KAFKA_BROKER_URL_TESTE=localhost:9095

# Zookeeper
ZOOKEEPER_HOST_TESTE=localhost
ZOOKEEPER_CLIENT_PORT_TESTE=2182

# Influx
INFLUX_USERNAME_TESTE=test_user
INFLUX_PASSWORD_TESTE=test_password
INFLUX_ORG_TESTE=test_org
INFLUX_BUCKET_TESTE=test_bucket
INFLUX_RETENTION_TESTE=1d
INFLUX_ADMIN_TOKEN_TESTE=test_token
INFLUX_HOST_TESTE=localhost
INFLUX_PORT_TESTE=8087
INFLUX_URL_TESTE=http://localhost:8087

# Observabilidade
OTEL_SERVICE_NAME=service-name
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_PROPAGATORS=tracecontext,baggage

# SMTP
SMTP_HOST_TESTE=smtp.example.com
SMTP_PORT_TESTE=587
SMTP_USER_TESTE=test_user
SMTP_PASS_TESTE=test_password
SMTP_FROM_TESTE=test@example.com

# API
API_BASE_URL_TESTE=http://localhost:3333
API_HOST_TESTE=0.0.0.0
API_PORT_TESTE=3333

# Dados de teste
ADMIN_EMAIL_TESTE=admin@example.com
ADMIN_PASSWORD_TESTE=password
USER_EMAIL_TESTE=user@example.com
USER_PASSWORD_TESTE=password
TECNICO_EMAIL_TESTE=tecnico@example.com
TECNICO_PASSWORD_TESTE=password

# Configurações de teste
TEST_TIMEOUT=30000
TEST_CONCURRENCY=1
SKIP_SEED=false
SKIP_MIGRATIONS=false